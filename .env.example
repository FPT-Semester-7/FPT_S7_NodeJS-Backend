# REQUIRED: Server Port
PORT=5000

# REQUIRED: Environment configuration (development, production)
NODE_ENV=development

# REQUIRED: MongoDB Connection URI (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/mchub

# REQUIRED: Secret key for JWT generation
JWT_SECRET=your_secret_here

# OPTIONAL: JWT Expiration duration
JWT_EXPIRES_IN=30d

# REQUIRED: Frontend URL for Payment redirects
FE_URL=http://localhost:5173

# REQUIRED: Allowed origins for CORS (comma-separated strings)
# Example: http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173

# REQUIRED for Payments: PayOS credentials
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# OPTIONAL: Cloudinary integration for image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
